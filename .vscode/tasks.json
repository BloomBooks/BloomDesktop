{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Create terminals",
            "dependsOn": ["BloomBrowserUI", "content"],
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "BloomBrowserUI",
            "type": "shell",
            "command": "bash",
            "options": {
                "cwd": "${workspaceFolder}/src/BloomBrowserUI"
            },
            // Mark as a background task to avoid the spinner animation on the terminal tab
            "isBackground": true,
            // Create the tasks in a terminal group (split)
            "presentation": {
                "group": "my-group"
            }
        },
        {
            "label": "content",
            "type": "shell",
            "command": "bash",
            "options": {
                "cwd": "${workspaceFolder}/src/content"
            },
            "isBackground": true,
            "presentation": {
                "group": "my-group"
            }
        },
        {
            "label": "Ensure Development Environment Initialized",
            "type": "shell",
            "command": "bash build/ensure-initialized.sh",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/Bloom.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/Bloom.sln",
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary;ForceNoAlign"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/Bloom.sln"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "flatten-appbuilder-icons",
            "type": "process",
            "command": "node",
            "args": [
                "${workspaceFolder}/.github/skills/rab-icon-grid-processing/flattenAppBuilderIcons.mjs"
            ],
            "problemMatcher": []
        },
        {
            "label": "test-rab-icon-choices",
            "type": "process",
            "command": "dotnet",
            "args": [
                "test",
                "${workspaceFolder}/src/BloomTests/BloomTests.csproj",
                "--filter",
                "GetAvailableIconChoices"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "crop-appbuilder-icon-samples",
            "type": "process",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.github/skills/rab-icon-grid-processing/cropAppBuilderIconSamples.ps1"
            ],
            "problemMatcher": []
        },
        {
            "label": "pilot-extract-appbuilder-icons",
            "type": "shell",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.github/skills/rab-icon-grid-processing/extractAppBuilderIconGridSamples.ps1",
                "-SourcePaths",
                "${workspaceFolder}/DistFiles/appbuilder-icons-old/bloom-ai2-01-open-book-stars.png",
                "${workspaceFolder}/DistFiles/appbuilder-icons-old/bloom-ai2-19-rocket-book.png",
                "-OutputRoot",
                "output\\copilot-verify\\appbuilder-icon-samples",
                "-MaxIconsPerSource",
                "2",
                "-StartNumber",
                "1"
            ],
            "isBackground": false,
            "problemMatcher": []
        }
    ]
}
