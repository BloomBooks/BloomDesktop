{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "lib": ["ES2022"],
        "types": ["node"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "outDir": "dist"
    },
    "include": ["harness/**/*.ts", "tests/**/*.ts", "playwright.config.ts"],
    "exclude": ["node_modules", "dist", "test-results"]
}
