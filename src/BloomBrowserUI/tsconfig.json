{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "sourceMap": true,
        "allowJs": true,
        "jsx": "react-jsx",
        "jsxImportSource": "@emotion/react",
        "esModuleInterop": true,
        "types": [
            /*"@emotion/core",*/
            "@emotion/react/types/css-prop",
            "vitest/globals",
            "@testing-library/jest-dom/types/index"
        ],
        "lib": ["dom", "es6", "scripthost", "es2019"],
        "experimentalDecorators": true,
        "alwaysStrict": true,
        "noImplicitReturns": true,
        "strictNullChecks": true,
        "outDir": "../../output/browser",
        //"resolveJsonModule": true,
        // this solved the 'foo' cannot be used as a JSX component. Its instance type 'foo' is not a valid JSX element,
        // which came in when we were at react 17 but some things are going towards 18
        "paths": {
            "react": ["./node_modules/@types/react"],
            "@emotion/react": ["./node_modules/@emotion/react"],
            "@emotion/react/*": ["./node_modules/@emotion/react/*"],
            "vitest": ["./node_modules/vitest"],
            "vitest/*": ["./node_modules/vitest/*"],
            "@testing-library/jest-dom": [
                "./node_modules/@testing-library/jest-dom"
            ]
        },
        "typeRoots": ["./node_modules/@types", "./node_modules"]
    },
    "exclude": [
        "node_modules",
        "typings",
        "react_components/component-tester",
        "react_components/**/component-tests",
        "vite.config.ts"
    ]
}
