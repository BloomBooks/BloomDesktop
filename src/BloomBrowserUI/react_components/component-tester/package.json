{
    "name": "component-tester",
    "private": true,
    "version": "0.0.0",
    "engines": {
        "node": ">=22.11.0"
    },
    "scripts": {
        "dev": "pnpm exec vite --config vite.config.ts --no-open",
        "test": "playwright test",
        "test:ui": "playwright test --ui --headed",
        "manual": "tsx scripts/manual.ts -- ",
        "manual:interactive": "playwright test --headed --timeout=0"
    },
    "dependencies": {
        "react": "17.0.2",
        "react-dom": "17.0.2"
    },
    "devDependencies": {
        "@playwright/test": "1.56.1",
        "@types/node": "22.18.11",
        "@types/react": "17.0.89",
        "@types/react-dom": "17.0.26",
        "@vitejs/plugin-react": "4.7.0",
        "typescript": "6.0.3",
        "vite": "5.4.20",
        "tsx": "4.20.6"
    },
    "packageManager": "pnpm@11.5.2"
}
